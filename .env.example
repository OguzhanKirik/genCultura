# Copy to .env and fill in values

# Database (overridden in docker-compose; needed for local dev without Docker)
DATABASE_URL=postgresql+asyncpg://gencultura:gencultura@localhost:5432/gencultura

# Security
SECRET_KEY=change-me-to-a-random-64-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM provider (vLLM, Ollama, or OpenAI)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Embedding provider
# If left empty, falls back to OPENAI_BASE_URL / OPENAI_API_KEY above.
# Set these when the embedding server is separate from the LLM server
# (e.g. two different Colab tunnels, or a dedicated Ollama instance).
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── Colab example (paste the block printed by Cell 7 of the notebook) ─────────
# OPENAI_BASE_URL=https://xxxx.ngrok-free.app/v1
# OPENAI_API_KEY=no-key
# LLM_MODEL=Qwen/Qwen2.5-3B-Instruct
# EMBEDDING_BASE_URL=https://yyyy.ngrok-free.app/v1
# EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
# EMBEDDING_DIMENSIONS=768

# Media storage
MEDIA_DIR=./media

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000
